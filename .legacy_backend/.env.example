# Backend Environment Variables
# Copy this file to .env and fill in your values

# Exa API key — get yours at https://dashboard.exa.ai/api-keys
EXA_API_KEY=YOUR_EXA_API_KEY_HERE

# GMI Cloud API key (optional) — enables DeepSeek-R1, Llama, Qwen models
# Get a key at https://app.gmi-serving.com/api-keys
GMI_CLOUD_API_KEY=YOUR_GMI_CLOUD_API_KEY_HERE

# Port (optional, defaults to 3001)
PORT=8080
